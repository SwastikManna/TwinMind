# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# OpenAI (required for /api/chat)
OPENAI_API_KEY=

# Groq (recommended free tier alternative)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Optional override for email callback URL. If empty, app uses window.location.origin.
NEXT_PUBLIC_DEV_SUPABASE_REDIRECT_URL=
